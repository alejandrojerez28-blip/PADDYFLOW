# Base de datos PostgreSQL
DATABASE_URL=postgres://postgres:postgres@localhost:5432/paddyflow

# JWT (generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Puerto del servidor
PORT=3001

# Stripe Billing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_BASIC=
STRIPE_PRICE_PRO=

# URLs (para Checkout, Portal y CORS)
# APP_BASE_URL: orígenes permitidos (comma-separated). Sin valor = localhost:5173
APP_BASE_URL=http://localhost:5173
API_BASE_URL=http://localhost:3001
